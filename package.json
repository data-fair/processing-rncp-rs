{
  "name": "@data-fair/processing-rncp-rs",
  "version": "2.0.0",
  "description": "Process RNCP and RS (France Compétences, flux V4-1) XML files to generate datasets.",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "prepare": "husky || true",
    "build-types": "export NODE_OPTIONS='--experimental-strip-types' && df-build-types ./",
    "test-base": "NODE_ENV=test node --experimental-strip-types --test-force-exit --test-concurrency=1 --test --test-reporter=spec --test-reporter-destination=stdout",
    "test": "npm run test-base test-it/*.ts"
  },
  "imports": {
    "#config": "./lib/config.ts",
    "#types/*": "./types/*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/data-fair/processing-rncp-rs.git"
  },
  "keywords": [
    "data-fair-processings-plugin"
  ],
  "author": "Benjamin Giraud-renard",
  "license": "AGPL-3.0-only",
  "bugs": {
    "url": "https://github.com/data-fair/processing-rncp-rs/issues"
  },
  "homepage": "https://github.com/data-fair/processing-rncp-rs#readme",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@data-fair/lib-common-types": "^1.20.6",
    "@data-fair/lib-processing-dev": "^0.2.0",
    "@data-fair/lib-types-builder": "^1.7.0",
    "@types/debug": "^4.1.13",
    "@types/fs-extra": "^11.0.4",
    "@types/html-to-text": "^9.0.4",
    "@types/sax": "^1.2.7",
    "config": "^4.4.1",
    "eslint": "^9.26.0",
    "husky": "^9.1.7",
    "neostandard": "^0.12.1",
    "typescript": "^5.8.3",
    "ws": "^8.19.0"
  },
  "files": [
    "processing-config-schema.json",
    "./lib/**/*"
  ],
  "relativeDependencies": {
    "@data-fair/lib-common-types": "../../lib/packages/common-types",
    "@data-fair/lib-processing-dev": "../../lib/packages/processing-dev"
  },
  "dependencies": {
    "@data-fair/lib-utils": "^1.10.2",
    "csv-stringify": "^6.5.0",
    "debug": "^4.4.0",
    "form-data": "^4.0.5",
    "fs-extra": "^11.3.4",
    "html-to-text": "^9.0.5",
    "sax": "^1.4.1"
  }
}
